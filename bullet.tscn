[gd_scene format=3 uid="uid://cpkkltuq0mw1p"]

[sub_resource type="GDScript" id="GDScript_rtl8c"]
script/source = "extends Area3D

const SPEED = 40
var damage: int = 1 

# 🔥 PŘEPÍNAČ: Kdo stiskl spoušť?
var shot_by_enemy: bool = false 

func _ready() -> void:
	body_entered.connect(_on_body_entered)
	await get_tree().create_timer(2.0).timeout
	queue_free()

func _physics_process(delta: float) -> void:
	# Letí vpřed směrem, kam je natočena
	global_translate(-global_transform.basis.z * SPEED * delta)

func _on_body_entered(body: Node3D) -> void:
	# --- 🔴 CHOVÁNÍ: STŘÍLÍ NEPŘÍTEL ---
	if shot_by_enemy:
		if body.name == \"player\": # Zasáhlo to tebe!
			if body.has_method(\"die\"):
				body.die()
			queue_free()
		elif body.has_method(\"take_damage\"):
			# Ignorujeme ostatní nepřátele (aby se nestříleli do zad)
			pass
		else:
			# Narazila do zdi
			queue_free()
			
	# --- 🔵 CHOVÁNÍ: STŘÍLÍ HRÁČ (Tvoje původní logika) ---
	else:
		if body.name == \"player\":
			return 
			
		if body.has_method(\"take_damage\"):
			body.take_damage(damage)
			
		queue_free()
"

